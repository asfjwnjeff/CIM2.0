'use client';

import React, { useState } from 'react';
import { useParams, useRouter } from 'next/navigation';
import Link from 'next/link';
import AppLayout from '@/components/layout/AppLayout';
import { useApp } from '@/lib/store';
import type { Quote, QuoteStatus } from '@/lib/types';

export default function QuoteDetailPage() {
  const params = useParams();
  const router = useRouter();
  const { salesQuotes } = useApp();
  const [sendDialogOpen, setSendDialogOpen] = useState(false);

  const quote = salesQuotes.find((q: Quote) => q.id === params.id);

  if (!quote) {
    return (
      <AppLayout>
        <div className="flex flex-col items-center justify-center h-full p-16">
          <div className="w-24 h-24 mx-auto mb-4 rounded-full bg-[#F5F6F8] flex items-center justify-center">
            <svg className="w-12 h-12 text-[#999999]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 className="text-lg font-medium text-[#1A1A1A] mb-2">报价单不存在</h3>
          <p className="text-[#666666] mb-6">找不到您要查看的报价单</p>
          <button
            onClick={() => router.push('/quotes')}
            className="bg-gradient-to-r from-[#1A2FFF] to-[#3B52FF] text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90 transition-all active:scale-[0.98] flex items-center gap-2"
          >
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            返回列表
          </button>
        </div>
      </AppLayout>
    );
  }

  const getStatusColor = (status: QuoteStatus) => {
    switch (status) {
      case 'pending': return 'bg-[#FFF5E5] text-[#FF6B00]';
      case 'pending_review': return 'bg-[#FFF5E5] text-[#FF6B00]';
      case 'accepted': return 'bg-[#E5F9F0] text-[#00A854]';
      case 'rejected': return 'bg-[#FCE8E8] text-[#E53935]';
      case 'sent': return 'bg-[#E5F2FF] text-[#1A2FFF]';
      case 'transferred': return 'bg-[#F0F0F0] text-[#666666]';
      default: return 'bg-[#F0F0F0] text-[#666666]';
    }
  };

  const getStatusText = (status: QuoteStatus) => {
    switch (status) {
      case 'pending': return '草稿';
      case 'pending_review': return '待审批';
      case 'accepted': return '已接受';
      case 'rejected': return '已拒绝';
      case 'sent': return '已发送';
      case 'transferred': return '已转商机';
      default: return status;
    }
  };

  const formatCurrency = (amount: number | undefined, currency: string) => {
    if (!amount) return '-';
    return new Intl.NumberFormat('zh-CN', {
      style: 'currency',
      currency: currency || 'CNY',
    }).format(amount);
  };

  const formatDate = (dateStr: string) => {
    return new Date(dateStr).toLocaleDateString('zh-CN');
  };

  const handleSendQuote = (type: 'pdf' | 'excel' | 'h5') => {
    if (type === 'pdf' && quote.pdfUrl) {
      window.open(quote.pdfUrl, '_blank');
    } else if (type === 'excel' && quote.excelUrl) {
      window.open(quote.excelUrl, '_blank');
    } else if (type === 'h5' && quote.h5Url) {
      navigator.clipboard.writeText(quote.h5Url);
      alert('H5链接已复制到剪贴板');
    }
    setSendDialogOpen(false);
  };

  return (
    <AppLayout>
      <div className="p-5">
        {/* Header */}
        <div className="flex items-center justify-between mb-6">
          <div className="flex items-center gap-4">
            <button
              onClick={() => router.back()}
              className="flex items-center gap-2 px-4 py-2.5 border border-[#EEEEEE] rounded-lg bg-white text-[#666666] hover:bg-[#F5F6F8] hover:text-[#1A1A1A] transition-all"
            >
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              返回
            </button>
            <div>
              <h1 className="text-2xl font-bold text-[#1A1A1A]">{quote.title}</h1>
              <p className="text-[#666666] mt-1">{quote.quoteNumber}</p>
            </div>
          </div>
          <div className="flex items-center gap-3">
            <span className={`px-3 py-1 rounded-full text-sm font-medium ${getStatusColor(quote.status)}`}>
              {getStatusText(quote.status)}
            </span>
            {quote.status === 'accepted' && (
              <button 
                onClick={() => setSendDialogOpen(true)}
                className="bg-gradient-to-r from-[#1A2FFF] to-[#3B52FF] text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90 transition-all active:scale-[0.98] flex items-center gap-2"
              >
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
                发送报价
              </button>
            )}
            <Link href={`/quotes/${quote.id}/edit`}>
              <button className="flex items-center gap-2 px-4 py-2.5 border border-[#EEEEEE] rounded-lg bg-white text-[#666666] hover:bg-[#F5F6F8] hover:text-[#1A1A1A] transition-all">
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                编辑
              </button>
            </Link>
          </div>
        </div>

        {/* Main Content */}
        <div className="grid grid-cols-3 gap-6">
          {/* Left Column */}
          <div className="col-span-2 space-y-6">
            {/* Basic Info */}
            <div className="bg-white rounded-xl border border-[#EEEEEE] p-6">
              <h2 className="text-lg font-semibold text-[#1A1A1A] mb-6">基本信息</h2>
              <div className="grid grid-cols-2 gap-6">
                <div>
                  <label className="block text-sm font-medium text-[#666666] mb-2">客户名称</label>
                  <p className="text-[#1A1A1A]">{quote.customerName}</p>
                </div>
                <div>
                  <label className="block text-sm font-medium text-[#666666] mb-2">报价标题</label>
                  <p className="text-[#1A1A1A]">{quote.title}</p>
                </div>
                <div>
                  <label className="block text-sm font-medium text-[#666666] mb-2">报价有效期</label>
                  <p className="text-[#1A1A1A]">
                    {formatDate(quote.validFrom)} - {formatDate(quote.validTo)}
                  </p>
                </div>
                <div>
                  <label className="block text-sm font-medium text-[#666666] mb-2">负责人</label>
                  <div className="flex items-center gap-2">
                    {quote.ownerName && (
                      <div className="w-8 h-8 rounded-full bg-gradient-to-r from-[#1A2FFF] to-[#3B52FF] flex items-center justify-center text-white text-sm font-medium">
                        {quote.ownerName?.[0]?.toUpperCase()}
                      </div>
                    )}
                    <span className="text-[#1A1A1A]">{quote.ownerName || '-'}</span>
                  </div>
                </div>
              </div>
            </div>

            {/* Quote Items */}
            <div className="bg-white rounded-xl border border-[#EEEEEE] p-6">
              <div className="flex items-center justify-between mb-6">
                <h2 className="text-lg font-semibold text-[#1A1A1A]">报价明细</h2>
                <button className="flex items-center gap-2 px-4 py-2 border border-[#1A2FFF] text-[#1A2FFF] rounded-lg hover:bg-[#1A2FFF]/5 transition-all">
                  <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
                  </svg>
                  添加项
                </button>
              </div>
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead className="bg-[#F8F9FC]">
                    <tr>
                      <th className="text-left px-4 py-3 text-sm font-medium text-[#1A1A1A]">项目</th>
                      <th className="text-left px-4 py-3 text-sm font-medium text-[#1A1A1A]">描述</th>
                      <th className="text-right px-4 py-3 text-sm font-medium text-[#1A1A1A]">数量</th>
                      <th className="text-right px-4 py-3 text-sm font-medium text-[#1A1A1A]">单价</th>
                      <th className="text-right px-4 py-3 text-sm font-medium text-[#1A1A1A]">金额</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-[#EEEEEE]">
                    {(quote.items || []).map((item, index) => (
                      <tr key={index}>
                        <td className="px-4 py-4 text-[#1A1A1A]">{item.name}</td>
                        <td className="px-4 py-4 text-[#666666]">{item.description || '-'}</td>
                        <td className="px-4 py-4 text-right text-[#1A1A1A]">{item.quantity}</td>
                        <td className="px-4 py-4 text-right text-[#1A1A1A]">
                          {formatCurrency(item.unitPrice, quote.currency)}
                        </td>
                        <td className="px-4 py-4 text-right font-medium text-[#1A1A1A]">
                          {formatCurrency(item.total, quote.currency)}
                        </td>
                      </tr>
                    ))}
                    {(quote.items || []).length === 0 && (
                      <tr>
                        <td colSpan={5} className="px-4 py-12 text-center text-[#666666]">
                          暂无报价明细
                        </td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
              <div className="mt-6 pt-6 border-t border-[#EEEEEE]">
                <div className="flex items-center justify-end gap-4">
                  <span className="text-[#666666]">总金额：</span>
                  <span className="text-2xl font-bold text-[#1A2FFF]">
                    {formatCurrency(quote.totalAmount, quote.currency)}
                  </span>
                </div>
              </div>
            </div>

            {/* History */}
            <div className="bg-white rounded-xl border border-[#EEEEEE] p-6">
              <h2 className="text-lg font-semibold text-[#1A1A1A] mb-6">操作历史</h2>
              <div className="space-y-4">
                {(quote.history || []).map((record, index) => (
                  <div key={index} className="flex items-start gap-4 pb-4 border-b border-[#F0F0F0] last:border-0 last:pb-0">
                    <div className="w-10 h-10 rounded-full bg-gradient-to-r from-[#1A2FFF] to-[#3B52FF] flex items-center justify-center text-white text-sm font-medium flex-shrink-0">
                      {record.operatorName?.[0]?.toUpperCase()}
                    </div>
                    <div className="flex-1">
                      <div className="flex items-center gap-2">
                        <span className="font-medium text-[#1A1A1A]">{record.operatorName}</span>
                        <span className="text-[#999999] text-sm">{formatDate(record.operatedAt)}</span>
                      </div>
                      <p className="text-[#666666] mt-1">{record.action}</p>
                      {record.comment && (
                        <p className="text-[#666666] mt-1 text-sm">备注：{record.comment}</p>
                      )}
                    </div>
                  </div>
                ))}
                {(quote.history || []).length === 0 && (
                  <p className="text-[#666666] text-center py-8">暂无操作历史</p>
                )}
              </div>
            </div>
          </div>

          {/* Right Column */}
          <div className="space-y-6">
            {/* Summary */}
            <div className="bg-white rounded-xl border border-[#EEEEEE] p-6">
              <h2 className="text-lg font-semibold text-[#1A1A1A] mb-6">报价摘要</h2>
              <div className="space-y-4">
                <div className="flex items-center justify-between">
                  <span className="text-[#666666]">总金额</span>
                  <span className="text-xl font-bold text-[#1A2FFF]">
                    {formatCurrency(quote.totalAmount, quote.currency)}
                  </span>
                </div>
                <div className="flex items-center justify-between">
                  <span className="text-[#666666]">状态</span>
                  <span className={`px-3 py-1 rounded-full text-sm font-medium ${getStatusColor(quote.status)}`}>
                    {getStatusText(quote.status)}
                  </span>
                </div>
                <div className="flex items-center justify-between">
                  <span className="text-[#666666]">创建时间</span>
                  <span className="text-[#1A1A1A]">{formatDate(quote.createdAt)}</span>
                </div>
                {quote.submittedAt && (
                  <div className="flex items-center justify-between">
                    <span className="text-[#666666]">提交时间</span>
                    <span className="text-[#1A1A1A]">{formatDate(quote.submittedAt)}</span>
                  </div>
                )}
              </div>
            </div>

            {/* Collaborators */}
            <div className="bg-white rounded-xl border border-[#EEEEEE] p-6">
              <div className="flex items-center justify-between mb-6">
                <h2 className="text-lg font-semibold text-[#1A1A1A]">协作人</h2>
                <button className="text-[#1A2FFF] hover:underline text-sm flex items-center gap-1">
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
                  </svg>
                  管理
                </button>
              </div>
              <div className="space-y-3">
                {(quote.collaborators || []).map((col, index) => (
                  <div key={index} className="flex items-center gap-3">
                    <div className="w-9 h-9 rounded-full bg-gradient-to-r from-[#1A2FFF] to-[#3B52FF] flex items-center justify-center text-white text-sm font-medium">
                      {(col.userName || col.name)?.[0]?.toUpperCase()}
                    </div>
                    <div className="flex-1">
                      <p className="text-[#1A1A1A] font-medium">{col.userName || col.name}</p>
                      <p className="text-[#999999] text-sm">{col.role || '协作人'}</p>
                    </div>
                  </div>
                ))}
                {(quote.collaborators || []).length === 0 && (
                  <p className="text-[#666666] text-center py-4 text-sm">暂无协作人</p>
                )}
              </div>
            </div>

            {/* Quick Actions */}
            <div className="bg-white rounded-xl border border-[#EEEEEE] p-6">
              <h2 className="text-lg font-semibold text-[#1A1A1A] mb-6">快捷操作</h2>
              <div className="space-y-3">
                <button className="w-full flex items-center gap-3 px-4 py-3 border border-[#EEEEEE] rounded-lg text-[#1A1A1A] hover:bg-[#F5F6F8] transition-all">
                  <svg className="w-5 h-5 text-[#666666]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  导出 PDF
                </button>
                <button className="w-full flex items-center gap-3 px-4 py-3 border border-[#EEEEEE] rounded-lg text-[#1A1A1A] hover:bg-[#F5F6F8] transition-all">
                  <svg className="w-5 h-5 text-[#666666]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  导出 Excel
                </button>
                <button className="w-full flex items-center gap-3 px-4 py-3 border border-[#EEEEEE] rounded-lg text-[#1A1A1A] hover:bg-[#F5F6F8] transition-all">
                  <svg className="w-5 h-5 text-[#666666]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                  </svg>
                  生成 H5 链接
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Send Dialog */}
      {sendDialogOpen && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
          <div className="bg-white rounded-xl shadow-xl max-w-md w-full mx-4">
            <div className="p-6 border-b border-[#EEEEEE]">
              <h3 className="text-lg font-semibold text-[#1A1A1A]">发送报价</h3>
              <p className="text-[#666666] mt-1">选择发送方式</p>
            </div>
            <div className="p-6 space-y-3">
              <button
                onClick={() => handleSendQuote('pdf')}
                className="w-full flex items-center gap-4 p-4 border border-[#EEEEEE] rounded-lg hover:bg-[#F5F6F8] transition-all"
              >
                <div className="w-12 h-12 bg-[#FCE8E8] rounded-lg flex items-center justify-center">
                  <svg className="w-6 h-6 text-[#E53935]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div className="text-left">
                  <h4 className="font-medium text-[#1A1A1A]">PDF 文件</h4>
                  <p className="text-[#666666] text-sm">下载 PDF 格式报价单</p>
                </div>
              </button>
              <button
                onClick={() => handleSendQuote('excel')}
                className="w-full flex items-center gap-4 p-4 border border-[#EEEEEE] rounded-lg hover:bg-[#F5F6F8] transition-all"
              >
                <div className="w-12 h-12 bg-[#E5F9F0] rounded-lg flex items-center justify-center">
                  <svg className="w-6 h-6 text-[#00A854]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div className="text-left">
                  <h4 className="font-medium text-[#1A1A1A]">Excel 表格</h4>
                  <p className="text-[#666666] text-sm">下载 Excel 格式报价单</p>
                </div>
              </button>
              <button
                onClick={() => handleSendQuote('h5')}
                className="w-full flex items-center gap-4 p-4 border border-[#EEEEEE] rounded-lg hover:bg-[#F5F6F8] transition-all"
              >
                <div className="w-12 h-12 bg-[#E5F2FF] rounded-lg flex items-center justify-center">
                  <svg className="w-6 h-6 text-[#1A2FFF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                  </svg>
                </div>
                <div className="text-left">
                  <h4 className="font-medium text-[#1A1A1A]">H5 链接</h4>
                  <p className="text-[#666666] text-sm">复制 H5 报价单链接</p>
                </div>
              </button>
            </div>
            <div className="p-6 border-t border-[#EEEEEE]">
              <button
                onClick={() => setSendDialogOpen(false)}
                className="w-full px-4 py-2.5 border border-[#EEEEEE] rounded-lg text-[#666666] hover:bg-[#F5F6F8] transition-all"
              >
                取消
              </button>
            </div>
          </div>
        </div>
      )}
    </AppLayout>
  );
}
