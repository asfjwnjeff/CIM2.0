{
  "skill": "unblind",
  "version": "2.2.0",
  "cases": [
    {"id": "should-describe", "prompt": "what's in this image?", "shouldTrigger": true, "assertions": ["返回非空文本描述"]},
    {"id": "should-ocr", "prompt": "OCR this receipt", "shouldTrigger": true, "assertions": ["提取所有文字"]},
    {"id": "should-chinese", "prompt": "帮我看看这张图里有什么", "shouldTrigger": true, "assertions": ["返回中文描述"]},
    {"id": "should-ui", "prompt": "review this UI mockup", "shouldTrigger": true, "assertions": ["返回设计评审意见"]},
    {"id": "should-chart", "prompt": "extract data from this chart", "shouldTrigger": true, "assertions": ["提取图表数据"]},
    {"id": "should-object", "prompt": "I need you to look at this photo and tell me what objects are in it", "shouldTrigger": true, "assertions": ["列出物体"]},
    {"id": "should-scan", "prompt": "read the text from this scanned document", "shouldTrigger": true, "assertions": ["提取文档文字"]},
    {"id": "should-diagram", "prompt": "describe this diagram", "shouldTrigger": true, "assertions": ["返回图表描述"]},
    {"id": "not-video", "prompt": "generate a video from this image", "shouldTrigger": false},
    {"id": "not-edit", "prompt": "edit this photo — remove the background", "shouldTrigger": false},
    {"id": "not-audio", "prompt": "play this audio file", "shouldTrigger": false},
    {"id": "not-pdf", "prompt": "read this PDF and summarize it", "shouldTrigger": false},
    {"id": "not-generate", "prompt": "create an image of a cat", "shouldTrigger": false},
    {"id": "not-csv", "prompt": "what does this CSV file contain?", "shouldTrigger": false},
    {"id": "not-write-script", "prompt": "write a bash script to resize images", "shouldTrigger": false},
    {"id": "not-chart-gen", "prompt": "generate a chart from this data", "shouldTrigger": false},
    {"id": "not-translate", "prompt": "translate this Spanish text to English", "shouldTrigger": false},
    {"id": "not-video-watch", "prompt": "I have a video file — can you watch it and tell me what happens?", "shouldTrigger": false},
    {"id": "error-no-key", "prompt": "analyze this image test.png", "shouldTrigger": true, "assertions": ["优雅降级", "引导设置API Key", "不泄露敏感信息"]},
    {"id": "error-bad-format", "prompt": "describe this file test.tiff", "shouldTrigger": true, "assertions": ["提示格式不支持"]}
  ]
}
